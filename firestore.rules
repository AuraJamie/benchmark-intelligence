rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /homeowners/{homeownerId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }
    
    match /projects/{projectId} {
      allow get: if true;
      allow list: if request.auth != null;
      allow update: if request.auth != null || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']) 
                    && request.resource.data.status == 'Contacted');
      allow create, delete: if request.auth != null;
    }

    match /agreements/{agreementId} {
      allow get: if true;
      allow update: if (request.auth != null && resource.data.status != 'Signed') || (
          // Allow public signing ONLY if status is Pending
          resource.data.status == 'Pending'
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'dateSigned', 'signatureData', 'auditTrail', 'finalized'])
          && (request.resource.data.status == 'Signed' || request.resource.data.status == 'Pending')
      );
      allow list, create, delete: if request.auth != null;
    }

    match /signedContracts/{contractId} {
      allow read: if request.auth != null;
      allow create: if true; // Technically created by Cloud Function via admin SDK, but doesn't hurt to be explicit about backend intent
      allow update, delete: if false; // Immutable audit records
    }

    match /builders/{builderId} {
      allow get: if true;
      allow list, create, update, delete: if request.auth != null;
    }

    match /contractVersions/{versionId} {
      allow get: if true;
      allow list, create, update, delete: if request.auth != null;
    }

    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
