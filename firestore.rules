rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /homeowners/{homeownerId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }
    
    match /projects/{projectId} {
      // Allow public to get a single project by ID (for the capture form)
      allow get: if true;
      allow list: if request.auth != null;
      // Allow public to update only the status to 'Contacted'
      allow update: if request.auth != null || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']) 
                    && request.resource.data.status == 'Contacted');
      allow create, delete: if request.auth != null;
    }

    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
