rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /homeowners/{homeownerId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }
    
    match /projects/{projectId} {
      allow get: if true;
      allow list: if request.auth != null;
      allow update: if request.auth != null || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']) 
                    && request.resource.data.status == 'Contacted');
      allow create, delete: if request.auth != null;
    }

    match /agreements/{agreementId} {
      allow get: if true;
      allow update: if request.auth != null || (
          // Allow public audit logging (only auditTrail) OR full signing
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'dateSigned', 'signatureData', 'auditTrail'])
          && resource.data.status == 'Pending'
          && (request.resource.data.status == 'Signed' || request.resource.data.status == 'Pending')
      );
      allow list, create, delete: if request.auth != null;
    }

    match /builders/{builderId} {
      allow get: if true;
      allow list, create, update, delete: if request.auth != null;
    }

    match /contractVersions/{versionId} {
      allow get: if true;
      allow list, create, update, delete: if request.auth != null;
    }

    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
